# Optional for development builds. Use a stable Apple Development or local code
# signing identity to avoid repeated Keychain trust prompts after each rebuild.
# Defaults to ad hoc signing.
# You can find this with: `security find-identity -v -p codesigning`
IRONSMITH_DEV_SIGN_IDENTITY="Apple Development: Your Name (TEAMID)"

# Optional. Pins the Codex CLI version bundled into app builds.
# Defaults to latest. `script/build.sh --codex-version <version>` takes precedence.
IRONSMITH_CODEX_VERSION="latest"
